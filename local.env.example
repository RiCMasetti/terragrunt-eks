# Copy this file to local.env, fill in your values, then:
#   source local.env

# ── AWS identity ──────────────────────────────────────────────────────────────
export AWS_ACCOUNT_ID=""
export AWS_DEFAULT_REGION=""

# export AWS_PROFILE=""

# Use explicit credentials
# export AWS_ACCESS_KEY_ID="AK..."
# export AWS_SECRET_ACCESS_KEY="BX..."

# ── Cluster ───────────────────────────────────────────────────────────────────
export TF_VAR_cluster_name=""
export TF_VAR_kubernetes_version="1.36"

# ── Node group ────────────────────────────────────────────────────────────────
# JSON array syntax is required — plain strings like "t3a.medium" are parsed
# by Terraform as HCL traversal expressions and cause a "Variables not allowed" error.
export TF_VAR_instance_types='["t3a.medium"]'
export TF_VAR_node_min_size="2"
export TF_VAR_node_max_size="5"
export TF_VAR_node_desired_size="3"

# ── Networking ────────────────────────────────────────────────────────────────
export TF_VAR_vpc_cidr="10.0.0.0/16"
export TF_VAR_single_nat_gateway="false"

# ── DNS / TLS ─────────────────────────────────────────────────────────────────
export TF_VAR_domain_name=""
export TF_VAR_route53_zone_id=""

# ── GitHub (used by Flux bootstrap) ──────────────────────────────────────────
export TF_VAR_github_org=""
export TF_VAR_github_repo="terragrunt-eks"

# ── Set terraform as iac executor  ───────────────────────────────────────────
# Comment this export to use open tofu instead 
export TG_TF_PATH=terraform
